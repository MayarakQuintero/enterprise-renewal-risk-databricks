    {
      "name": "3b750a9f",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT SUM(CASE WHEN risk_bucket = 'High' THEN 1 ELSE 0 END)/COUNT(*) AS pct_high_risk\n",
        "FROM renewal_dashboard_base;\n",
        "\n"
      ]
    },
    {
      "name": "fe65b6dc",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT ROUND(SUM(revenue_at_risk),0) AS total_revenue_at_risk\n",
        "FROM renewal_dashboard_base;\n"
      ]
    },
    {
      "name": "2cf28ecb",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "  risk_bucket,\n",
        "  COUNT(*) AS accounts,\n",
        "  ROUND(SUM(revenue_at_risk), 0) AS revenue_at_risk\n",
        "FROM renewal_dashboard_base\n",
        "GROUP BY risk_bucket\n",
        "ORDER BY\n",
        "  CASE\n",
        "    WHEN risk_bucket = 'High' THEN 1\n",
        "    WHEN risk_bucket = 'Medium' THEN 2\n",
        "    ELSE 3\n",
        "  END"
      ]
    }
  ],
