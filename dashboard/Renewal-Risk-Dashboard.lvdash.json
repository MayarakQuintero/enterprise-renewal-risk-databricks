      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT ROUND(SUM(non_renewal_probability), 1) AS expected_churn_count\n",
        "FROM renewal_dashboard_base;\n"
      ]
    },
    {
      "name": "aec8d036",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT COUNT(*) AS high_risk_accounts \n",
        "FROM renewal_dashboard_base\n",
        "WHERE risk_bucket = 'High';"
      ]
    },
    {
      "name": "36145959",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT ROUND(100.0 * SUM(CASE WHEN risk_bucket = 'High' THEN 1 ELSE 0 END)/COUNT(*),1) AS pct_high_risk\n",
        "FROM renewal_dashboard_base;\n",
        "\n"
      ]
    },
