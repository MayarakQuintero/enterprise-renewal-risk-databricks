{
  "datasets": [
    {
      "name": "a6a03a67",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "  COUNT (*) AS accounts_scored,\n",
        "  SUM(CASE WHEN risk_bucket = 'High' THEN 1 ELSE 0 END) AS high_risk_accounts,\n",
        "  ROUND(SUM(revenue_at_risk), 2) AS total_revenue_at_risk, \n",
        "  ROUND(AVG(non_renewal_probability), 4) AS avg_churn_probability\n",
        "FROM renewal_dashboard_base; \n"
      ]
    },
    {
      "name": "f74e5142",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "  risk_bucket, \n",
        "  COUNT(*) AS account_count, \n",
        "  ROUND(SUM(revenue_at_risk), 2) AS revenue_at_risk\n",
        "FROM renewal_dashboard_base\n",
        "GROUP BY risk_bucket\n",
        "ORDER BY revenue_at_risk DESC;"
      ]
    },
    {
      "name": "225b37ad",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "  risk_rank,\n",
        "  client_id,\n",
        "  industry,\n",
        "  region,\n",
        "  company_size,\n",
        "  contract_end_date,\n",
        "  ROUND(non_renewal_probability, 4) AS non_renewal_probability,\n",
        "  ROUND(annual_contract_value, 2) AS annual_contract_value,\n",
        "  ROUND(revenue_at_risk, 2) AS revenue_at_risk,\n",
        "  top_driver_summary,\n",
        "  recommended_action\n",
        "FROM renewal_dashboard_base\n",
        "ORDER BY risk_rank\n",
        "LIMIT 5;"
      ]
    },
    {
      "name": "fba81ada",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "  client_id,\n",
        "  driver_priority,\n",
        "  driver_name,\n",
        "  driver_explanation\n",
        "  -- ROUND(non_renewal_probability, 4) AS non_renewal_probability,\n",
        "  -- ROUND(revenue_at_risk, 2) AS revenue_at_risk\n",
        "FROM renewal_account_driver_detail\n",
        "ORDER BY client_id, driver_priority;"
      ]
    }
  ],
