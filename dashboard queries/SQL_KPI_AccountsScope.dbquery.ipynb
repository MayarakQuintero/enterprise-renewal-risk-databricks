       "command": "-- SELECT \n-- COUNT(*) AS accounts_in_scope, \n-- SUM(CASE WHEN risk_bucket = 'High' THEN 1 ELSE 0 END) AS high_risk_accounts, \n-- ROUND(100.0 * SUM(CASE WHEN risk_bucket = 'High' THEN 1 ELSE 0 END)/COUNT(*),1) AS pct_high_risk,\n-- ROUND(SUM(revenue_at_risk), 0) AS total_revenue_at_risk, \n-- ROUND(SUM(non_renewal_probability), 1) AS expected_churn_count\n-- FROM renewal_dashboard_base\n\nSELECT COUNT(*) AS accounts_in_scope\nFROM renewal_dashboard_base;\n\nSELECT COUNT(*) AS high_risk_accounts \nFROM renewal_dashboard_base\nWHERE risk_bucket = 'High';\n\nSELECT ROUND(100.0 * SUM(CASE WHEN risk_bucket = 'High' THEN 1 ELSE 0 END)/COUNT(*),1) AS pct_high_risk\nFROM renewal_dashboard_base;\n\nSELECT ROUND(SUM(revenue_at_risk),0) AS total_revenue_at_risk\nFROM renewal_dashboard_base;\n\nSELECT ROUND(SUM(non_renewal_probability), 1) AS expected_churn_count\nFROM renewal_dashboard_base;\n",
